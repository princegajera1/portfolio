# Firebase Configuration Environment Variables
# Copy this file to .env.local and replace the PLACEHOLDER values with your actual credentials.
# Firebase credentials: Firebase Console > Project Settings > General > Your apps
# EmailJS credentials: https://www.emailjs.com/ > Account > Services / Templates / Account

VITE_FIREBASE_API_KEY=YOUR_ACTUAL_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=prince-portfolio-155bf.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=prince-portfolio-155bf
VITE_FIREBASE_STORAGE_BUCKET=prince-portfolio-155bf.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_ACTUAL_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_ACTUAL_APP_ID
VITE_FIREBASE_MEASUREMENT_ID=YOUR_ACTUAL_MEASUREMENT_ID

# EmailJS — Contact form email notifications
VITE_EMAILJS_SERVICE_ID=YOUR_EMAILJS_SERVICE_ID
VITE_EMAILJS_TEMPLATE_ID=YOUR_EMAILJS_TEMPLATE_ID
VITE_EMAILJS_PUBLIC_KEY=YOUR_EMAILJS_PUBLIC_KEY

# GitHub Integration
VITE_GITHUB_USERNAME=princegajera1
