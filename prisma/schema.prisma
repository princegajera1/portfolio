datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Hero {
  id           String @id @default("1")
  name         String
  title        String
  subtitleText String
  resumeUrl    String
}

model About {
  id           String @id @default("1")
  bio          String
  avatarUrl    String
  yearsExp     String
  projectsDone String
  clients      String
  techPills    String // Serialized JSON array of strings
}

model Skill {
  id       String @id @default(uuid())
  name     String
  level    Int
  category String
}

model Project {
  id          String  @id @default(uuid())
  title       String
  description String
  tech        String  // Serialized JSON array of strings
  github      String
  demo        String
  featured    Boolean @default(true)
  image       String
}

model Experience {
  id          String @id @default(uuid())
  role        String
  company     String
  period      String
  description String // Serialized JSON array of strings
  initials    String
}

model Contact {
  id       String @id @default("1")
  email    String
  phone    String
  location String
  linkedin String
  github   String
  twitter  String
}

model Message {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}
